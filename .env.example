# =========================================================
# APPLICATION
# =========================================================
APP_NAME=Enterprise GraphRAG Agentic AI
APP_VERSION=2.0.0
DEBUG=false

# =========================================================
# SUPABASE
# =========================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# =========================================================
# NEO4J
# =========================================================
NEO4J_URI=bolt://medical_neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-secure-neo4j-password

# =========================================================
# REDIS
# =========================================================
REDIS_URL=redis://medical_redis:6379

# =========================================================
# MINIO
# =========================================================
MINIO_ENDPOINT=medical-minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=chat-attachments
MINIO_SECURE=false
MINIO_PUBLIC_ENDPOINT=localhost:9000

# =========================================================
# HUGGING FACE AUTHENTICATION
# =========================================================
HF_API_TOKEN=hf_GANTI_DENGAN_TOKEN_ANDA

# =========================================================
# TEXT LLM ROUTING
# =========================================================
LLM_BASE_URL=https://router.huggingface.co/v1
HF_PROVIDER=auto
MODEL_FAST=meta-llama/Llama-3.1-8B-Instruct
MODEL_THINKING=Qwen/Qwen2.5-7B-Instruct
LLM_DEFAULT_MODEL=meta-llama/Llama-3.1-8B-Instruct
LLM_FALLBACK_MODEL=Qwen/Qwen2.5-7B-Instruct
FAST_MAX_TOKENS=1000
THINKING_MAX_TOKENS=2200
FAST_TEMPERATURE=0.35
THINKING_TEMPERATURE=0.25
MODEL_REQUEST_TIMEOUT_SECONDS=90
MODEL_MAX_RETRIES=2
ALLOW_MODEL_FALLBACK=true
MODEL_HEALTHCHECK_ENABLED=true

# =========================================================
# REMOTE VLM
# =========================================================
VLM_BACKEND=hf_router
VLM_PROVIDER=auto
VLM_ROUTER_BASE_URL=https://router.huggingface.co/v1

# Digunakan hanya jika memakai Hugging Face Inference Endpoint.
VLM_ENDPOINT_URL=

VLM_PRIMARY_MODEL=zai-org/GLM-4.5V:cheapest
VLM_FALLBACK_MODELS=CohereLabs/command-a-vision-07-2025:cohere
VLM_ALLOW_MODEL_SUBSTITUTION=true
VLM_DISABLED_MODELS=Qwen/Qwen2.5-VL-7B-Instruct
VLM_REQUEST_TIMEOUT_SECONDS=180
VLM_CONNECT_TIMEOUT_SECONDS=15
VLM_MAX_RETRIES_PER_MODEL=1
VLM_MAX_NEW_TOKENS=1200
VLM_TEMPERATURE=0.1
VLM_MAX_FILE_SIZE_MB=10
VLM_MAX_IMAGE_PIXELS=12000000
VLM_MAX_IMAGES_PER_REQUEST=4
VLM_MAX_BASE64_BYTES=12000000
VLM_HEALTHCHECK_ENABLED=true
VLM_AVAILABILITY_CACHE_SECONDS=600
VLM_FAILURE_COOLDOWN_SECONDS=600

# =========================================================
# ATTACHMENT
# =========================================================
ATTACHMENT_MAX_SIZE_MB=20
ATTACHMENT_CONTEXT_MAX_CHARS=12000
ATTACHMENT_MAX_PDF_PAGES=30
ATTACHMENT_PROCESSING_ASYNC=true
ATTACHMENT_STATUS_TTL_SECONDS=86400

# =========================================================
# VERIFICATION
# =========================================================
NEO4J_ATTACHMENT_VERIFICATION=true
ATTACHMENT_MIN_CONFIDENCE=0.55
ATTACHMENT_HIGH_CONFIDENCE=0.80

# =========================================================
# EMBEDDING + CORS
# =========================================================
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-base
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
