# Enterprise GraphRAG Agentic AI - Environment Variables
# Copy file ini ke .env dan isi value yang sesuai
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•

# â”€â”€â”€ APLIKASI â”€â”€â”€
APP_NAME=Enterprise GraphRAG Agentic AI
APP_VERSION=2.0.0
DEBUG=false

# â”€â”€â”€ SUPABASE (PostgreSQL + pgvector + Auth) â”€â”€â”€
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...your-service-role-key

# â”€â”€â”€ NEO4J (Graph Database) â”€â”€â”€
NEO4J_URI=bolt://medical_neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-secure-neo4j-password

# â”€â”€â”€ REDIS (Rate Limiting) â”€â”€â”€
REDIS_URL=redis://medical_redis:6379

# â”€â”€â”€ MINIO (Object Storage) â”€â”€â”€
MINIO_ENDPOINT=medical_minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=chat-attachments
MINIO_SECURE=false
MINIO_PUBLIC_ENDPOINT=localhost:9000

# â”€â”€â”€ LLM via OpenRouter â”€â”€â”€
LLM_API_KEY=sk-or-v1-your-openrouter-api-key
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-sonnet-4

# â”€â”€â”€ EMBEDDING MODEL â”€â”€â”€
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-base

# â”€â”€â”€ CORS â”€â”€â”€
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Hugging Face
HF_API_TOKEN=hf_GANTI_DENGAN_TOKEN_ASLI

# â”€â”€â”€ OCR WORKER â”€â”€â”€
OCR_WORKER_URL=http://medical_ocr_worker:8010
OCR_WORKER_TIMEOUT_SECONDS=180
OCR_WORKER_ENABLED=true

# â”€â”€â”€ GOT-OCR2 â”€â”€â”€
OCR_MODEL_ID=stepfun-ai/GOT-OCR-2.0-hf
OCR_MODEL_FALLBACK_ID=stepfun-ai/GOT-OCR2_0
OCR_DEVICE=auto
OCR_DTYPE=auto
OCR_MAX_NEW_TOKENS=2048
OCR_TIMEOUT_SECONDS=120
OCR_LAZY_LOAD=true
OCR_TRUST_REMOTE_CODE=false
OCR_ENABLE_FALLBACK=true
OCR_MAX_IMAGE_PIXELS=16000000
OCR_CACHE_ENABLED=true

# â”€â”€â”€ ATTACHMENT â”€â”€â”€
ATTACHMENT_MAX_SIZE_MB=20
ATTACHMENT_CONTEXT_MAX_CHARS=12000
ATTACHMENT_MAX_PDF_PAGES=30
ATTACHMENT_OCR_PAGE_LIMIT=15

# â”€â”€â”€ VERIFICATION â”€â”€â”€
NEO4J_ATTACHMENT_VERIFICATION=true
ATTACHMENT_MIN_CONFIDENCE=0.55
ATTACHMENT_HIGH_CONFIDENCE=0.80
