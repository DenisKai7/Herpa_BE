# ═══════════════════════════════════════════════════════
# Enterprise GraphRAG Agentic AI - Environment Variables
# Copy file ini ke .env dan isi value yang sesuai
# ═══════════════════════════════════════════════════════

# ─── APLIKASI ───
APP_NAME=Enterprise GraphRAG Agentic AI
APP_VERSION=2.0.0
DEBUG=false

# ─── SUPABASE (PostgreSQL + pgvector + Auth) ───
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...your-service-role-key

# ─── NEO4J (Graph Database) ───
NEO4J_URI=bolt://medical_neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-secure-neo4j-password

# ─── REDIS (Rate Limiting) ───
REDIS_URL=redis://medical_redis:6379

# ─── MINIO (Object Storage) ───
MINIO_ENDPOINT=medical_minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=chat-attachments
MINIO_SECURE=false

# ─── LLM via OpenRouter ───
LLM_API_KEY=sk-or-v1-your-openrouter-api-key
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-sonnet-4

# ─── EMBEDDING MODEL ───
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-base

# ─── CORS ───
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
